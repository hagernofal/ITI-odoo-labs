<odoo>
    <record id="hms_patient_list" model="ir.ui.view">
    <field name="name">hms.patient.list</field>
    <field name="model">hms.patient</field>
    <field name="arch" type="xml">
        <list>
            <field name="first_name"/>
            <field name="last_name"/>
            <field name="email"/>
            <field name="department_id"/>
            <field name="department_capacity"/>
            <field name="state"/>
            <field name="age"/>
        </list>
    </field>
    </record>

    <record id="hms_patient_form" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form>

                <sheet>

                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="birth_date"/>
                            <field name="age"/>
                            <field name="email"/>
                        </group>

                        <group>
                            <field name="department_id"/>
                            <field name="department_capacity"/>

                            <field name="doctor_ids"  readonly="department_id == False"
                                widget="many2many_tags"/>
                        </group>
                    </group>

                    <group>
                        <field name="blood_type"/>
                        <field name="state"/>
                        <field name="pcr"/>
                        <field name="cr_ratio" required="pcr == True"/>
                    </group>

                    <group>
                        <field name="image" widget="image"/>
                        <field name="address"/>
                    </group>

                    <notebook>

                        <page string="History" invisible="age &lt; 50">
                            <field name="history"/>
                        </page>

                        <page string="Logs">

                            <field name="log_ids" readonly="True">

                                <list editable="bottom">
                                    <field name="created_by"/>
                                    <field name="log_date"/>
                                    <field name="description"/>
                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="action_hms_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,form</field>
    </record>


    <menuitem id="menu_hms_root" name="HMS"/>

    <menuitem id="menu_hms_patient"
            name="Patients"
            parent="menu_hms_root"
            action="action_hms_patient" sequence="1"/>
</odoo>
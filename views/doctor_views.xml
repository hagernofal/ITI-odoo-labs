<odoo>
    <record id="hms_doctor_list" model="ir.ui.view">
    <field name="name">hms.doctor.list</field>
    <field name="model">hms.doctor</field>
    <field name="arch" type="xml">
        <list>
            <field name="first_name"/>
            <field name="last_name"/>
        </list>
    </field>
    </record>

    <record id="hms_doctor_form" model="ir.ui.view">
        <field name="name">hms.doctor.form</field>
        <field name="model">hms.doctor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="first_name"/>
                        <field name="last_name"/>
                    </group>

                    <group>
                        <field name="image" widget="image"/>
                    </group>

                    <notebook>
                        <page string="Patients">
                            <field name="patient_ids"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hms_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hms.doctor</field>
        <field name="view_mode">list,form</field>
    </record>



    <menuitem id="menu_hms_doctor"
            name="Doctors"
            parent="menu_hms_root"
            action="action_hms_doctor" sequence="3"/>
            
</odoo>